GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Optional: sends an email when someone is invited to a project, via your own
# Gmail account. Without these, invites still work — just silently (in-app only).
# GMAIL_APP_PASSWORD is NOT your regular Gmail password — generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
